# ─────────────────────────────────────────────────────────────────────────────
# Gradle
# ─────────────────────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ─────────────────────────────────────────────────────────────────────────────
# Secrets & local env — NEVER commit
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Logs & temp
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.hprof
*.tmp

# ─────────────────────────────────────────────────────────────────────────────
# IntelliJ IDEA
# ─────────────────────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ─────────────────────────────────────────────────────────────────────────────
# Eclipse / STS
# ─────────────────────────────────────────────────────────────────────────────
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
bin/

# ─────────────────────────────────────────────────────────────────────────────
# NetBeans
# ─────────────────────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ─────────────────────────────────────────────────────────────────────────────
# VS Code
# ─────────────────────────────────────────────────────────────────────────────
.vscode/

# ─────────────────────────────────────────────────────────────────────────────
# OS cruft
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Bruno — per-developer secret values
# ─────────────────────────────────────────────────────────────────────────────
bruno/**/environments/*.local.bru
bruno/**/*.bru.env

# ─────────────────────────────────────────────────────────────────────────────
# AI planning (.planning/) is INTENTIONALLY tracked — this is an AI-first repo.
# The GSD workspace, codebase intel, and phase plans are committed on purpose.
# Claude session state, however, stays local:
# ─────────────────────────────────────────────────────────────────────────────
.claude/

# Local design specs — never committed.
docs/

# Visual brainstorm sessions
.superpowers/
