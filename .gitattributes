# Force LF line endings for all text files.
* text=auto eol=lf

*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bru text eol=lf

# Gradle wrapper script.
/gradlew text eol=lf

# Windows batch — needs CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never diff or merge.
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary

# Keep generated/build output out of GitHub language stats.
build/** linguist-generated=true
