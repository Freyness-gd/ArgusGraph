config.stopBubbling = true

# Add @Generated so Checkstyle, JaCoCo, and SpotBugs skip Lombok-generated code.
lombok.addLombokGeneratedAnnotation = true

# Copy Spring's @Lazy from field to the generated constructor parameter so
# @RequiredArgsConstructor works on beans with self-references / circular deps.
lombok.copyableAnnotations += org.springframework.context.annotation.Lazy

# @SneakyThrows hides checked exceptions from the call site.
lombok.sneakyThrows.flagUsage = warning
# try-with-resources is standard Java.
lombok.cleanup.flagUsage = error
